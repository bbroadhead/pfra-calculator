{
  "expo": {
    "name": "PFRA Calculator",
    "slug": "pfra-calculator",
    "scheme": "pfra-calculator",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png",
      "output": "static",
      "themeColor": "#0A1628",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
